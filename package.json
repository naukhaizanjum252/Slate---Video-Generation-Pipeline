{
  "name": "slate",
  "version": "1.0.0",
  "private": true,
  "description": "Slate — Trello-driven video content pipeline automation for Bodycam Horror Studio",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @slate/shared build",
    "build:watcher": "pnpm --filter @slate/watcher build",
    "build:dashboard": "pnpm --filter @slate/dashboard build",
    "dev:watcher": "pnpm --filter @slate/watcher dev",
    "dev:dashboard": "pnpm --filter @slate/dashboard dev",
    "typecheck": "pnpm -r typecheck",
    "start:watcher": "pnpm --filter @slate/watcher start"
  }
}
