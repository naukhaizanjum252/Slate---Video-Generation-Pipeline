# ─── Public (browser) ─────────────────────────────────────
# Read-only anon access used by the dashboard to display episodes/channels.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Server-only (NEVER prefixed NEXT_PUBLIC) ─────────────
# Used by the dashboard's API routes to manage channels and proxy Trello.
# The service-role key bypasses RLS — keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=
# Trello key + token power the board/list dropdowns on the Settings page.
TRELLO_API_KEY=
TRELLO_TOKEN=

# Google OAuth (Web application client) powers the "Connect Google Drive" button
# + folder dropdown on the Settings page. This must be a WEB client (not the
# Desktop client) with this app's callback registered as an authorized redirect
# URI: <your-dashboard-url>/api/drive/oauth/callback  (and the same for
# http://localhost:3000 for local dev).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: only set if the request origin differs from the public URL (proxy /
# custom domain). Must exactly match a registered redirect URI.
# GOOGLE_OAUTH_REDIRECT_URI=https://your-dashboard-url/api/drive/oauth/callback
