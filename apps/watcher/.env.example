# ─── Trello ───────────────────────────────────────────────
# Get key + token from https://trello.com/app-key
# Board + list IDs are NO LONGER set here — they live per-channel in Supabase
# and are managed from the dashboard Settings page.
TRELLO_API_KEY=
TRELLO_TOKEN=

# ─── Gradio (Bodycam Studio) ──────────────────────────────
# Watcher runs on the same droplet as the Gradio tool, so call it locally.
GRADIO_BASE_URL=http://localhost:7860

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Drive (OAuth) ─────────────────────────────────
# Uploads run as the real account that owns the folder. Service accounts can't
# store files in a personal Gmail Drive (no quota), so we use OAuth.
#
# The connected account is normally set from the dashboard ("Connect Google
# Drive" on the Settings page) and stored in Supabase — the watcher reads it at
# upload time, so switching accounts needs no redeploy. The client id/secret
# below are still required (they're used to refresh the access token).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# OPTIONAL fallback refresh token, used only if no account has been connected in
# the dashboard yet. Get one with the CLI helper (run on a machine with a browser):
#   GOOGLE_OAUTH_CLIENT_ID=... GOOGLE_OAUTH_CLIENT_SECRET=... \
#     pnpm --filter @slate/watcher get-drive-token
GOOGLE_OAUTH_REFRESH_TOKEN=

# ─── Pipeline ─────────────────────────────────────────────
# Build the final stitched MP4 (/cb_build_video). Off by default — current scope
# is just the asset bundle. Set to true to render video.
ENABLE_BUILD_VIDEO=false

# OPTIONAL hard cap on one episode (minutes). Default is OFF (no cap), so a
# slow-but-progressing run is never killed for taking too long — only the stall
# watchdog below stops it. Set a positive value to re-impose an absolute ceiling.
# PIPELINE_TIMEOUT_MIN=0
# PRIMARY guard: fail an episode if progress doesn't CHANGE for this many minutes
# (a true stall). Lower it to react faster; raise it if a legitimately slow step
# can go this long between progress updates.
# STALL_TIMEOUT_MIN=30
# systemd unit of the Gradio studio — its journal is captured into the error on a
# failure so you can see the real cause. Set blank to disable.
# STUDIO_LOG_UNIT=bodycam-studio

# Reuse already-generated output: before generating, probe /cb_download_all and,
# if a COMPLETE bundle already exists for the episode, just upload it (skips the
# expensive generation — great for retries). On by default.
# REUSE_EXISTING=true
# Max minutes to wait on the reuse probe before falling back to a full run.
# PROBE_TIMEOUT_MIN=2

# ─── Optional ─────────────────────────────────────────────
# Override path to python3 if not on PATH
# PYTHON_BIN=python3

# Poll interval using 6-field cron (includes seconds field).
# Default: every 60 seconds. Format: "*/N * * * * *"
POLL_CRON=*/60 * * * * *

# How many episodes to process at once (default 5). MUST stay within the upstream
# 69labs / studio concurrency caps — each episode uses ~4 concurrent image jobs,
# so N episodes need ~4N image slots (plus voiceover/script capacity). Set to 1
# for the old strictly-sequential behavior.
# MAX_CONCURRENT_EPISODES=5

# ─── Video mode (per-channel toggle in the dashboard) ─────
# When a channel has "Video mode" on, the watcher builds the full MP4, applies
# the freeze+flash+boom effect at the card's EFFECT_PAUSING_TIMESTAMP, stitches
# the card's intro video onto the front, and uploads ONLY that video. Requires
# ffmpeg + ffprobe on this host (the studio droplet already has them).
# Override the binaries only if they're not on PATH:
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
# Boom SFX path (defaults to apps/watcher/src/assets/sfx/boom.wav):
# BOOM_SFX_PATH=/abs/path/to/boom.wav
